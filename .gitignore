.venv/
.venv-ai/
.venv-linux/
__pycache__/
*.pyc
build/
dist/
*.svg
!assets/**/*.svg

# Build Linux (gros binaires, regenerables via build_linux.sh) ; le script et le
# spec restent versionnes.
*.AppImage
appimagetool-x86_64.AppImage
VectorPop.AppDir/
VectorPop_*_linux_x86_64.tar.gz
AppRun
vectorpop.desktop

# Snap (gros binaires + build dir, regenerables via snap-build/pack_snap.sh)
snap-build/*.snap
snap-build/dist/

# Packs d'assets generes (reproductibles via make_iconset.py / make_msix_assets.py)
icons/
msix_assets/

# Payload MSIX assemble (Assets+VFS = copies de dist/ et msix_assets/, regenerable) ;
# seul AppxManifest.xml (la source reelle) est versionne.
msix_payload/Assets/
msix_payload/VFS/

# Paquets .msix signes (gros binaires, regenerables via le payload + makeappx/signtool)
releases/

# Site (TanStack Start) : deps, build, secrets
site/node_modules/
site/.output/
site/.vercel/
site/.tanstack/
site/.env
site/.env.*
!site/.env.example
